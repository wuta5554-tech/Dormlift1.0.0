{
  "name": "campusmove-backend",
  "version": "1.0.0",
  "description": "Campus Move - NZ Student Moving Platform (Email Verification)",
  "main": "server.js",
  "scripts": {
    "start": "NODE_ENV=production node server.js",          // 生产启动（指定环境变量）
    "dev": "NODE_ENV=development nodemon server.js",       // 开发调试（自动重启）
    "pm2:start": "NODE_ENV=production pm2 start server.js --name campusmove",  // 生产进程守护
    "pm2:logs": "pm2 logs campusmove",                     // 查看生产日志（排错用）
    "clean": "rm -rf node_modules package-lock.json && npm install"  // 修复依赖问题
  },
  "dependencies": {
    "express": "^4.19.2",
    "sqlite3": "^5.1.7",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "nodemailer": "^6.9.13"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"  // 仅开发环境用，生产不安装
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": ["nz-student", "email-verification", "moving-platform", "nodejs"],
  "author": "",
  "license": "MIT",
  "private": true  // 标记为私有项目，避免意外发布
}
